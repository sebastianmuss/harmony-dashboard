generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── NextAuth Tables ──────────────────────────────────────────────────────────
// Required by @next-auth/prisma-adapter for database-backed sessions

// Model names must match what @next-auth/prisma-adapter expects.
// @@map directives keep our own table naming convention.

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // HARMONY role data — populated on first login, refreshed on each login
  role                String  @default("patient")
  patientId           Int?    @unique
  providerId          Int?    @unique
  patientCode         String?
  center              String?
  shiftId             Int?
  shiftName           String?
  shiftSchedule       String?
  dialysisSchedule    String?
  customDialysisDays  String?
  kickedAt            DateTime?  // set by admin to revoke JWT sessions

  accounts Account[]
  sessions Session[]

  @@map("auth_users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("auth_accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("auth_sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("auth_verification_tokens")
}

// ─── Shifts ──────────────────────────────────────────────────────────────────
// 5 fixed shifts at the Austrian dialysis centre
model Shift {
  id         Int       @id @default(autoincrement())
  name       String    @unique  // e.g. "MWF Morning"
  schedule   String    // "MWF" | "TThS"
  timeOfDay  String    // "morning" | "noon" | "evening"
  sortOrder  Int       @default(0)

  patients   Patient[]
  providers  Provider[]

  @@map("shifts")
}

// ─── Patients ─────────────────────────────────────────────────────────────────
model Patient {
  id                  Int       @id @default(autoincrement())
  patientCode         String    @unique  // HMY-XXXX pseudonymous identifier
  pin                 String    @unique  // patient password, stored as bcrypt hash
  pinIndexHash        String?   @unique  // legacy field — no longer used
  shiftId             Int
  center              String    @default("Feldbach")  // "Feldbach" | "Vienna"
  dialysisSchedule    String    @default("MWF")       // "MWF" | "TThS" | "custom"
  customDialysisDays  String?                         // comma-separated day numbers e.g. "1,3,5" when schedule="custom"
  enrollmentDate      DateTime  @db.Date
  isActive            Boolean   @default(true)
  droppedOutAt        DateTime? @db.Date
  dryWeight           Decimal?  @db.Decimal(5, 2)  // target dry weight (kg)
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shift          Shift     @relation(fields: [shiftId], references: [id])
  promResponses  PromResponse[]
  clinicalData   ClinicalData[]
  dailyOverrides DailyScheduleOverride[]

  @@map("patients")
}

// ─── Providers ───────────────────────────────────────────────────────────────
model Provider {
  id           Int      @id @default(autoincrement())
  name         String
  username     String   @unique
  passwordHash String
  role         String   // "admin" | "provider"
  shiftId      Int?     // null for admins
  center       String?  // "Feldbach" | "Vienna" — null means access to all centers (admins)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shift        Shift?   @relation(fields: [shiftId], references: [id])

  @@map("providers")
}

// ─── PROM Responses ───────────────────────────────────────────────────────────
// Patient-Reported Outcome Measures — 3 scores on 1-5 school-grade scale
// (1 = optimal, 5 = very bad)
model PromResponse {
  id                  Int      @id @default(autoincrement())
  patientId           Int
  sessionDate         DateTime @db.Date
  studyWeek           Int      // 1-12
  timepointReference  String   // "yesterday" | "arrival" | "now"
  fluidStatusScore    Int      // 1-5: general wellbeing, bad in either direction
  thirstScore         Int      // 1-5
  fluidOverloadScore  Int      // 1-5
  recoveryTime        String?  // '0-2h' | '3-6h' | '7-12h' | '>12h' — optional
  submittedAt         DateTime @default(now())

  patient             Patient  @relation(fields: [patientId], references: [id])

  @@unique([patientId, sessionDate])
  @@index([sessionDate])
  @@index([patientId, studyWeek])
  @@map("prom_responses")
}

// ─── Clinical Data ────────────────────────────────────────────────────────────
// Entered by clinical staff during rounds
model ClinicalData {
  id                       Int      @id @default(autoincrement())
  patientId                Int
  sessionDate              DateTime @db.Date
  preDialysisWeight        Decimal? @db.Decimal(5, 2)  // kg
  interdialyticWeightGain  Decimal? @db.Decimal(4, 2)  // kg
  systolicBp               Int?     // mmHg
  diastolicBp              Int?     // mmHg
  recordedAt               DateTime @default(now())

  patient                  Patient  @relation(fields: [patientId], references: [id])

  @@unique([patientId, sessionDate])
  @@index([sessionDate])
  @@map("clinical_data")
}

// ─── Daily Schedule Override ──────────────────────────────────────────────────
// One-time "treat this patient as on HD today" override set by a provider
model DailyScheduleOverride {
  id        Int      @id @default(autoincrement())
  patientId Int
  date      DateTime @db.Date
  patient   Patient  @relation(fields: [patientId], references: [id])
  createdAt DateTime @default(now())

  @@unique([patientId, date])
  @@index([date])
  @@map("daily_schedule_overrides")
}

// ─── Activity Log ─────────────────────────────────────────────────────────────
// Tracks logins, PROM submissions, and data views per actor
model ActivityLog {
  id        Int      @id @default(autoincrement())
  eventType String   // 'login' | 'prom_submit' | 'data_view'
  actorType String   // 'patient' | 'provider' | 'admin'
  actorId   Int?     // patientId or providerId
  center    String?
  shiftId   Int?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([actorId, actorType])
  @@index([createdAt])
  @@map("activity_logs")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────
// Append-only record of all data-modifying actions (DSGVO accountability)
model AuditLog {
  id         Int      @id @default(autoincrement())
  timestamp  DateTime @default(now())
  actorType  String   // 'admin' | 'provider' | 'patient' | 'system'
  actorId    Int?     // providerId or patientId
  action     String   // 'create' | 'update' | 'delete' | 'view' | 'export' | 'import' | 'failed_login'
  resource   String   // 'patient' | 'provider' | 'prom' | 'clinical' | 'config'
  resourceId Int?
  changes    Json?    // { field: { before, after } } — never includes PINs/passwords
  ip         String?
  hash       String?  // SHA-256 of this entry's content — used for tamper detection
  prevHash   String?  // hash of the immediately preceding AuditLog row (null / GENESIS for first)

  @@index([resource, resourceId])
  @@index([actorId])
  @@index([timestamp])
  @@map("audit_logs")
}

// ─── Study Configuration ──────────────────────────────────────────────────────
// Single row — insert once, update study start date to kick off week calculation
model StudyConfig {
  id             Int      @id @default(autoincrement())
  studyStartDate DateTime @db.Date
  studyName      String   @default("HARMONY")
  updatedAt      DateTime @updatedAt

  @@map("study_config")
}
